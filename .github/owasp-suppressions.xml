<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:noNamespaceSchemaLocation="dependency-suppression.1.3.xsd">
    <!--
        GHSA-88m4-h43f-wx84 / CVSSv3 9.1 (critical)
        pmd-core 7.9.0 — PMD Designer's GPG release-key passphrase committed
        to the PMD source repo and shipped in the Maven Central artifact.
        Impact: exposure of PMD's own artifact-signing key; no exploitable
        attack surface in our build. PMD is used only at analysis time
        (maven-pmd-plugin), not as a runtime or transitive runtime dependency.
        Suppressed until a patched release that removes the passphrase from
        the distributed artifact is available and adopted.
    -->
    <suppress>
        <notes>GHSA-88m4-h43f-wx84: GPG key passphrase in PMD artifact — build-time tool only, no runtime impact</notes>
        <gav regex="true">^net\.sourceforge\.pmd:pmd-(core|java):.*$</gav>
        <vulnerabilityName>GHSA-88m4-h43f-wx84</vulnerabilityName>
    </suppress>
</suppressions>
